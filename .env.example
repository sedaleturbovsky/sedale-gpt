# Required
ANTHROPIC_API_KEY=sk-ant-...
EXA_API_KEY=...

# Required only if you enable the privileged route (Composio side-effects)
COMPOSIO_API_KEY=...
COMPOSIO_USER_ID=sedale@opengrants.io
SEDALE_GPT_PRIVILEGED_TOKEN=generate-a-long-random-string

# Optional
PUBLIC_URL=https://opengrants-sedale-gpt.fly.dev
PORT=8080
LOG_LEVEL=INFO
DAILY_INPUT_TOKEN_CEILING=20000000
DAILY_OUTPUT_TOKEN_CEILING=2000000
MAX_CONCURRENT_TASKS=3
